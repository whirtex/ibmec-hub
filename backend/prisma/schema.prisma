// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id                 Int            @id @default(autoincrement())
  name               String
  email              String         @unique
  passwordHash       String
  role               String         @default("company") // "company" or "admin"
  companyProfile     CompanyProfile?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
}

model CompanyProfile {
  id                 Int            @id @default(autoincrement())
  userId             Int            @unique
  user               User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  cnpj               String         @unique
  companySize        String         // "micro", "pequena", "media", "grande"
  ibmecRelationship  String         // "sim" or "nao"
  industry           String         // "tecnologia", "saude", "educacao", "financeiro", "outro"
  demandType         String         // "consultoria", "desenvolvimento", "pesquisa", "outro"
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
}

model Project {
  id                 Int            @id @default(autoincrement())
  slug               String         @unique
  title              String
  category           String
  active             Boolean        @default(true)
  messages           ContactMessage[]
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
}

model ContactMessage {
  id                 Int            @id @default(autoincrement())
  type               String         // "institutional" or "project"
  projectId          Int?
  project            Project?       @relation(fields: [projectId], references: [id], onDelete: SetNull)
  name               String
  email              String
  subject            String
  message            String
  status             String         @default("queued") // "queued", "sent", "failed"
  createdAt          DateTime       @default(now())
}
